#!/bin/sh

# 1. Identify staged files
STAGED_FILES=$(git diff --cached --name-only)

# If no staged files, just exit
if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# 2. Categorize changes
# Metadata patterns: Beads, Conductor, Agent artifacts, and core project docs
BEADS_MATCHES=$(echo "$STAGED_FILES" | grep -E "^\.beads/" | wc -l)
CONDUCTOR_MATCHES=$(echo "$STAGED_FILES" | grep -E "^conductor/|^plan\.md|^task\.md" | wc -l)
AGENT_DOC_MATCHES=$(echo "$STAGED_FILES" | grep -E "^LEARNINGS\.gemini\.md|^walkthrough\.md|^implementation_plan\.md|^AGENTS\.md|^GEMINI\.md" | wc -l)

TOTAL_FILES=$(echo "$STAGED_FILES" | wc -l)
METADATA_FILES_COUNT=$((BEADS_MATCHES + CONDUCTOR_MATCHES + AGENT_DOC_MATCHES))

# 3. ENFORCEMENT: Beads must be used with Conductor
if [ "$BEADS_MATCHES" -gt 0 ]; then
    # Check for conductor file changes
    if [ "$CONDUCTOR_MATCHES" -eq 0 ]; then
        # Check for any active in-progress track as a fallback
        ACTIVE_TRACKS=$(grep -r "\"status\": \"in-progress\"" conductor/tracks/ 2>/dev/null | wc -l)
        if [ "$ACTIVE_TRACKS" -eq 0 ]; then
            echo "❌ ERROR: Beads data modified without corresponding Conductor context."
            echo "This project requires Beads to be used only in conjunction with Conductor."
            echo "Please update your Conductor plan or track metadata before committing Beads changes."
            exit 1
        fi
    fi
fi

# 4. OPTIMIZATION: Metadata-only commits skip heavy checks
if [ "$TOTAL_FILES" -eq "$METADATA_FILES_COUNT" ]; then
    echo "📝 Metadata-only commit detected. Skipping verification suite..."
    bun run format:check
    exit 0
fi

# 5. Standard Workflow (Source code changed)
echo "🚀 Source changes detected. Running full verification suite..."

bun run format:check
git add -u
bun run lint:fix
bun run lint:css:fix
bun run typecheck
bun run test:ci
bun run test:scripts
git add -u
