/*
  Content-Security-Policy: default-src 'self'; script-src 'self' www.googletagmanager.com static.cloudflareinsights.com browser.sentry-cdn.com 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: www.google-analytics.com www.googletagmanager.com; font-src 'self'; connect-src 'self' https://nms-optimizer-service-afebcfd47e2a.herokuapp.com wss://nms-optimizer-service-afebcfd47e2a.herokuapp.com https://*.google-analytics.com https://*.googletagmanager.com https://api.nms-optimizer.app https://cloudflareinsights.com https://*.ingest.us.sentry.io https://*.sentry.io browser.sentry-cdn.com; frame-src https://www.youtube.com; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; upgrade-insecure-requests;
