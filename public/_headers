# HTML Pages: Browser always revalidates, edge caches for 1 hour
# Safe because CF Pages purges cache on every deploy and assets are content-hashed
/
  Cache-Control: public, max-age=0, s-maxage=31536000, must-revalidate, stale-while-revalidate=60
/index.html
  Cache-Control: public, max-age=0, s-maxage=31536000, must-revalidate, stale-while-revalidate=60
/about/*
  Cache-Control: public, max-age=0, s-maxage=31536000, must-revalidate, stale-while-revalidate=60
/instructions/*
