	"faq": {
		"name": "NMS-Optimierer Häufig Gestellte Fragen",
		"questions": {
			"adjacencyBonus": {
				"name": "Was ist ein Adjazenzbonus in No Man's Sky?",
				"answer": "Wenn du kompatible Technologiemodule nebeneinander platzierst, erhalten sie einen Stat-Boost. Module desselben Typs, die eine Kante teilen, erhalten eine prozentuale Steigerung ihrer Effektivität. Je mehr Kanten geteilt werden, desto größer ist der Bonus."
			},
			"superchargedSlots": {
				"name": "Was sind überladene Slots und wie funktionieren sie?",
				"answer": "Überladene Slots bieten einen massiven Multiplikator auf die Basiswerte jedes dort platzierten Technologiemoduls. Dieser Boost wird zusätzlich zu den normalen Adjazenzboni angewendet, was ihre Platzierung entscheidend für Hochleistungs-Builds macht."
			},
			"maximizeBonus": {
				"name": "Wie maximiere ich Adjazenzboni und überladene Slots?",
				"answer": "Um die höchsten Werte zu erzielen, gruppiere ähnliche Technologien in Quadrat- oder 'L'-Form und platziere deine stärksten Module (wie die Hauptwaffe oder den Kernmotor) in überladenen Slots, die an andere Module der Gruppe angrenzen."
			},
			"calculation": {
				"name": "Wie findet der NMS-Optimierer das beste Technologie-Layout?",
				"answer": "Der Optimierer nutzt fortschrittliche Algorithmen, um in Sekundenschnelle Tausende möglicher Anordnungen zu erkunden. Er bewertet jedes Layout basierend auf Adjazenzboni, Multiplikatoren für überladene Slots und modulspezifischen Gewichtungen, um das mathematische Optimum für deine Ausrüstung zu finden."
			},
			"platforms": {
				"name": "Welche Ausrüstung und Schiffstypen unterstützt der NMS-Optimierer?",
				"answer": "Der NMS-Optimierer unterstützt alle wichtigen Ausrüstungen: Raumschiffe (einschließlich Wächter- und lebende Schiffe), Korvetten, Multitools, Exo-Anzüge, Exofahrzeuge und Frachter."
			}
		}
	},
