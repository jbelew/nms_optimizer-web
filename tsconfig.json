{
	"compilerOptions": {
		"paths": {
			"@/*": ["./src/*"]
		},
		"target": "esnext",
		"lib": ["dom", "esnext"],
		"allowJs": true,
		"skipLibCheck": true,
		"strict": true,
		"forceConsistentCasingInFileNames": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "react-jsx",
		"types": ["vite/client", "vitest/globals", "@testing-library/jest-dom", "@playwright/test"]
	},
	"include": ["src"],
	"exclude": ["node_modules", "**/tmp", "/tmp", "**/dist"]
}
