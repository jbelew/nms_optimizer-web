{
	"name": "nms_optimizer",
	"private": true,
	"version": "7.2.8",
	"type": "module",
	"scripts": {
		"dev": "bun x vite",
		"docs:generate": "bun x typedoc",
		"prebuild": "bun scripts/generate-radix-colors.mjs",
		"build": "bun x tsc -b && bun x vite build --mode production && bun scripts/generate-ssg.mjs && bun run sitemap",
		"build:docker": "VITE_DOCKER=true bun x vite build --mode docker && VITE_DOCKER=true bun scripts/generate-ssg.mjs && VITE_DOCKER=true bun run sitemap",
		"build:e2e": "bun x vite build --mode e2e",
		"build:images": "bun scripts/process-images.mjs",
		"lint:fix": "bun x eslint . --fix",
		"lint": "bun x eslint .",
		"lint:css": "bun x stylelint '**/*.scss'",
		"lint:css:fix": "bun x stylelint '**/*.scss' --fix",
		"sitemap": "bun scripts/generate-sitemap.mjs",
		"preview": "bun x vite preview",
		"serve:ssg": "bun scripts/serve-ssg.mjs",
		"screenshot": "bun scripts/screenshot.cjs",
		"screenshot:mobile-bg": "bun scripts/screenshot-blurred-background.js",
		"test": "bun x vitest run -c vitest.unit.config.ts --coverage && bun run test:scripts",
		"test:scripts": "bun test scripts/",
		"test:storybook": "bun x vitest run",
		"test:storybook:watch": "bun x vitest",
		"test:storybook:a11y": "bun x vitest run --reporter=verbose",
		"test:e2e": "bun run build:e2e && bun x playwright test",
		"test:ci": "bun x vitest run -c vitest.unit.config.ts --coverage",
		"typecheck": "bun x tsc --noEmit",
		"verify:ssg": "bun scripts/verify-ssg.mjs",
		"verify:routes": "bun scripts/verify-routes-consistency.mjs",
		"verify:deployment": "bun scripts/verify-deployment.mjs",
		"format:check": "bun x prettier --check ./src",
		"format": "bun x prettier --write ./src",
		"format:locales": "bun x prettier --write \"public/assets/locales/**/*.json\"",
		"start": "bun server/index.js",
		"heroku-postbuild": "bun run build",
		"prepare": "husky",
		"storybook": "bun x storybook dev -p 6006",
		"build-storybook": "STORYBOOK_BUILD=true bun x storybook build",
		"release": "bun x semantic-release",
		"lighthouse:ci": "bun x lhci autorun --config=scripts/lighthouserc.cjs --base-dir=/tmp/lighthouse-ci",
		"perf:check": "bun scripts/performance-check.mjs"
	},
	"dependencies": {
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-icons": "^1.3.2",
		"@radix-ui/react-toast": "^1.2.15",
		"@radix-ui/react-toolbar": "^1.1.11",
		"@radix-ui/themes": "^3.3.0",
		"@sentry/react": "^10.53.1",
		"compression": "^1.8.1",
		"express": "^5.2.1",
		"express-static-gzip": "^3.0.1",
		"html-to-image": "^1.11.13",
		"i18next": "^26.2.0",
		"i18next-browser-languagedetector": "^8.2.1",
		"i18next-fs-backend": "^2.6.5",
		"i18next-http-backend": "^4.0.0",
		"immer": "^11.1.8",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-ga4": "^3.0.1",
		"react-i18next": "^17.0.8",
		"react-is": "^19.2.6",
		"react-markdown": "^10.1.0",
		"react-router-dom": "^7.15.1",
		"recharts": "^3.8.1",
		"rehype-raw": "^7.0.0",
		"remark-gfm": "^4.0.1",
		"socket.io-client": "^4.8.3",
		"web-vitals": "^5.2.0",
		"zustand": "^5.0.13"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@babel/preset-env": "^7.29.5",
		"@babel/runtime": "^7.29.2",
		"@chromatic-com/storybook": "^5.2.1",
		"@commitlint/cli": "^21.0.1",
		"@commitlint/config-conventional": "^21.0.1",
		"@elsikora/commitizen-plugin-commitlint-ai": "^2.5.0",
		"@eslint/js": "^10.0.1",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@lhci/cli": "^0.15.1",
		"@playwright/test": "^1.60.0",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@rolldown/plugin-babel": "^0.2.3",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/exec": "^7.1.0",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.8",
		"@sentry/vite-plugin": "^5.3.0",
		"@storybook/addon-a11y": "^10.4.0",
		"@storybook/addon-docs": "^10.4.0",
		"@storybook/addon-vitest": "^10.4.0",
		"@storybook/react-vite": "^10.4.0",
		"@storybook/test": "^8.6.15",
		"@tailwindcss/postcss": "^4.3.0",
		"@tailwindcss/vite": "^4.3.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.8.0",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/compression": "^1.8.1",
		"@types/node": "^25.8.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript-eslint/eslint-plugin": "^8.59.3",
		"@typescript-eslint/parser": "^8.59.3",
		"@vitejs/plugin-react": "^6.0.2",
		"@vitest/browser": "^4.1.6",
		"@vitest/browser-playwright": "^4.1.6",
		"@vitest/coverage-v8": "^4.1.6",
		"@vitest/ui": "^4.1.6",
		"autoprefixer": "^10.5.0",
		"babel-plugin-react-compiler": "^1.0.0",
		"browserslist": "^4.28.2",
		"commitizen": "^4.3.1",
		"conventional-changelog": "^7.2.0",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.5",
		"eslint-plugin-jsdoc": "^62.9.0",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"eslint-plugin-storybook": "^10.4.0",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"lighthouse": "^13.3.0",
		"lightningcss": "^1.32.0",
		"marked": "^18.0.3",
		"marked-gfm-heading-id": "^4.1.4",
		"playwright": "^1.59.1",
		"postcss": "^8.5.14",
		"prettier": "^3.8.3",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"puppeteer": "^25.0.2",
		"puppeteer-core": "^25.0.2",
		"rollup-plugin-visualizer": "^7.0.1",
		"sass": "^1.99.0",
		"semantic-release": "^25.0.3",
		"sharp": "^0.34.5",
		"storybook": "^10.4.0",
		"stylelint": "^17.11.1",
		"stylelint-config-prettier-scss": "^1.0.0",
		"stylelint-config-standard": "^40.0.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"stylelint-order": "^8.1.1",
		"supertest": "^7.2.2",
		"typedoc": "^0.28.19",
		"typedoc-plugin-markdown": "^4.11.0",
		"typescript": "~6.0.3",
		"typescript-eslint": "^8.59.3",
		"vite": "^8.0.13",
		"vite-plugin-compression": "^0.5.1",
		"vite-plugin-pwa": "^1.3.0",
		"vite-plugin-splash-screen": "^0.2.0",
		"vitest": "^4.1.6",
		"vitest-websocket-mock": "^0.5.0",
		"wrangler": "^4.92.0"
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/@elsikora/commitizen-plugin-commitlint-ai/index.cjs"
		}
	}
}
