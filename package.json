{
	"name": "nms_optimizer",
	"private": true,
	"version": "7.4.1",
	"type": "module",
	"sideEffects": [
		"src/components/AppDialog/Base/AppDialog.tsx",
		"**/*.scss",
		"**/*.css"
	],
	"engines": {
		"node": ">=24.0.0",
		"bun": ">=1.2.0"
	},
	"scripts": {
		"dev": "bunx vite",
		"docs:generate": "bunx typedoc",
		"prebuild": "bun scripts/generate-radix-colors.mjs",
		"build": "bunx tsgo -b && bunx vite build --mode production && bun scripts/generate-ssg.mjs && bun run sitemap",
		"build:docker": "VITE_DOCKER=true bunx vite build --mode docker && VITE_DOCKER=true bun scripts/generate-ssg.mjs && VITE_DOCKER=true bun run sitemap",
		"build:e2e": "bunx vite build --mode e2e",
		"build:images": "bun scripts/process-images.mjs",
		"lint:fast": "bunx oxlint",
		"lint:fix": "bunx oxlint --fix && bunx eslint . --fix",
		"lint": "bunx oxlint && bunx eslint .",
		"lint:css": "bunx stylelint '**/*.scss'",
		"lint:css:fix": "bunx stylelint '**/*.scss' --fix",
		"lint:circular": "bunx madge --circular --extensions ts,tsx --ts-config tsconfig.json src/",
		"lint:knip": "bunx knip",
		"size": "bunx size-limit",
		"bench": "bun scripts/run-bench.mjs",
		"bench:build": "bun run build && bun scripts/run-bench.mjs",
		"sitemap": "bun scripts/generate-sitemap.mjs",
		"preview": "bunx vite preview",
		"serve:ssg": "bun scripts/serve-ssg.mjs",
		"screenshot": "bun scripts/screenshot.mjs",
		"screenshot:mobile-bg": "bun scripts/screenshot-blurred-background.js",
		"test": "bunx vitest run --project unit --coverage && bun run test:scripts",
		"test:scripts": "bun test scripts/",
		"test:storybook": "bunx vitest run --project storybook",
		"test:storybook:watch": "bunx vitest --project storybook",
		"test:storybook:a11y": "bunx vitest run --project storybook --reporter=verbose",
		"test:e2e": "bun run build:e2e && bunx playwright test",
		"test:ci": "bunx vitest run --project unit --coverage",
		"typecheck": "bunx tsgo --noEmit",
		"verify:ssg": "bun scripts/verify-ssg.mjs",
		"verify:routes": "bun scripts/verify-routes-consistency.mjs",
		"verify:deployment": "bun scripts/verify-deployment.mjs",
		"format:check": "bunx prettier --check ./src",
		"format": "bunx prettier --write ./src",
		"format:locales": "bunx prettier --write \"public/assets/locales/**/*.json\"",
		"prepare": "lefthook install",
		"storybook": "bunx storybook dev -p 6006",
		"build-storybook": "STORYBOOK_BUILD=true bunx storybook build",
		"release": "bunx semantic-release",
		"lighthouse:ci": "bunx lhci autorun --config=scripts/lighthouserc.cjs --base-dir=/tmp/lighthouse-ci",
		"perf:check": "bun scripts/performance-check.mjs"
	},
	"dependencies": {
		"@radix-ui/react-dialog": "^1.1.17",
		"@radix-ui/react-icons": "^1.3.2",
		"@radix-ui/react-toast": "^1.2.17",
		"@radix-ui/react-toolbar": "^1.1.13",
		"@radix-ui/themes": "^3.3.0",
		"@sentry/react": "^10.59.0",
		"html-to-image": "^1.11.13",
		"i18next": "^26.3.1",
		"i18next-browser-languagedetector": "^8.2.1",
		"i18next-fs-backend": "^2.6.6",
		"i18next-http-backend": "^4.0.0",
		"immer": "^11.1.8",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-ga4": "^3.0.1",
		"react-i18next": "^17.0.8",
		"react-is": "^19.2.7",
		"react-markdown": "^10.1.0",
		"react-router-dom": "^7.18.0",
		"recharts": "^3.8.1",
		"rehype-raw": "^7.0.0",
		"remark-gfm": "^4.0.1",
		"socket.io-client": "^4.8.3",
		"web-vitals": "^5.3.0",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@babel/core": "^8.0.1",
		"@babel/runtime": "^8.0.0",
		"@chromatic-com/storybook": "^5.2.1",
		"@commitlint/cli": "^21.0.2",
		"@commitlint/config-conventional": "^21.0.2",
		"@eslint/js": "^10.0.1",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@lhci/cli": "^0.15.1",
		"@playwright/test": "^1.61.0",
		"@radix-ui/react-tooltip": "^1.2.10",
		"@rolldown/plugin-babel": "^0.2.3",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/exec": "^7.1.0",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.8",
		"@sentry/vite-plugin": "^5.3.0",
		"@size-limit/file": "^12.1.0",
		"@storybook/addon-a11y": "^10.4.6",
		"@storybook/addon-docs": "^10.4.6",
		"@storybook/addon-vitest": "^10.4.6",
		"@storybook/react": "^10.4.6",
		"@storybook/react-vite": "^10.4.6",
		"@storybook/test": "^8.6.15",
		"@tailwindcss/vite": "^4.3.1",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.8.0",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^26.0.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260619.1",
		"@vitejs/plugin-react": "^6.0.2",
		"@vitest/browser": "^4.1.9",
		"@vitest/browser-playwright": "^4.1.9",
		"@vitest/coverage-v8": "^4.1.9",
		"@vitest/ui": "^4.1.9",
		"babel-plugin-react-compiler": "^1.0.0",
		"browserslist": "^4.28.2",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.5",
		"eslint-plugin-import-x": "^4.16.2",
		"eslint-plugin-jsdoc": "^63.0.6",
		"eslint-plugin-perfectionist": "^5.9.1",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-react-refresh": "^0.5.3",
		"eslint-plugin-storybook": "^10.4.6",
		"globals": "^17.6.0",
		"jsdom": "^29.1.1",
		"knip": "^6.17.1",
		"lefthook": "^2.1.9",
		"lightningcss": "^1.32.0",
		"madge": "^8.0.0",
		"marked": "^18.0.5",
		"oxlint": "^1.70.0",
		"playwright": "^1.61.0",
		"prettier": "^3.8.4",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"rollup-plugin-visualizer": "^7.0.1",
		"sass": "^1.101.0",
		"semantic-release": "^25.0.5",
		"sharp": "^0.35.2",
		"size-limit": "^12.1.0",
		"storybook": "^10.4.6",
		"stylelint": "^17.13.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"stylelint-order": "^8.1.1",
		"tachometer": "^0.7.2",
		"typedoc": "^0.28.19",
		"typescript": "~6.0.3",
		"typescript-eslint": "^8.61.1",
		"vite": "^8.0.16",
		"vite-plugin-pwa": "^1.3.0",
		"vite-plugin-splash-screen": "^0.2.0",
		"vitest": "^4.1.9"
	}
}
