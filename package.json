{
	"name": "nms_optimizer",
	"private": true,
	"version": "6.35.5",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"docs:generate": "typedoc",
		"prebuild": "node scripts/generate-radix-colors.mjs",
		"build": "tsc -b && vite build --mode production && node scripts/generate-ssg.mjs && npm run sitemap",
		"build:docker": "DOCKER=true vite build --mode docker && node scripts/generate-ssg.mjs && npm run sitemap",
		"build:critical": "tsc -b && vite build --mode critical && node scripts/generate-ssg.mjs && npm run sitemap",
		"build:e2e": "vite build --mode e2e",
		"build:images": "node scripts/process-images.mjs",
		"lint:fix": "eslint . --fix",
		"lint": "eslint .",
		"lint:css": "stylelint '**/*.scss'",
		"lint:css:fix": "stylelint '**/*.scss' --fix",
		"lint:mcp": "eslint --mcp",
		"sitemap": "node scripts/generate-sitemap.mjs",
		"preview": "vite preview",
		"serve:ssg": "node scripts/serve-ssg.mjs",
		"screenshot": "node scripts/screenshot.cjs",
		"screenshot:mobile-bg": "node scripts/screenshot-blurred-background.js",
		"test": "vitest run -c vitest.unit.config.ts --coverage && vitest run -c vitest.scripts.config.ts",
		"test:scripts": "vitest run -c vitest.scripts.config.ts",
		"test:storybook": "vitest run",
		"test:storybook:watch": "vitest",
		"test:storybook:a11y": "vitest run --reporter=verbose",
		"test:e2e": "npm run build:e2e && playwright test",
		"test:ci": "vitest run -c vitest.unit.config.ts --coverage",
		"typecheck": "tsc --noEmit",
		"verify:ssg": "node scripts/verify-ssg.mjs",
		"format:check": "prettier --check --write ./src",
		"format": "prettier --write ./src",
		"format:locales": "prettier --write \"public/assets/locales/**/*.json\"",
		"coverage:merge": "vitest coverage merge",
		"coverage:report": "vitest coverage report --reporter=lcov --reporter=text",
		"start": "node server/index.js",
		"heroku-postbuild": "vite build && node scripts/generate-ssg.mjs",
		"prepare": "husky",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "STORYBOOK_BUILD=true storybook build",
		"release": "semantic-release",
		"lighthouse:ci": "lhci autorun --config=scripts/lighthouserc.cjs --base-dir=/tmp/lighthouse-ci",
		"perf:check": "node scripts/performance-check.mjs",
		"perf:report": "open PERFORMANCE_REPORT.html || xdg-open PERFORMANCE_REPORT.html"
	},
	"dependencies": {
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-icons": "^1.3.2",
		"@radix-ui/react-toast": "^1.2.15",
		"@radix-ui/react-toolbar": "^1.1.11",
		"@radix-ui/themes": "^3.3.0",
		"@sentry/react": "^10.50.0",
		"compression": "^1.8.1",
		"express": "^5.2.1",
		"express-static-gzip": "^3.0.0",
		"html-to-image": "^1.11.13",
		"i18next": "^26.0.7",
		"i18next-browser-languagedetector": "^8.2.1",
		"i18next-fs-backend": "^2.6.5",
		"i18next-http-backend": "^3.0.6",
		"immer": "^11.1.4",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-ga4": "^3.0.1",
		"react-i18next": "^17.0.4",
		"react-is": "^19.2.5",
		"react-markdown": "^10.1.0",
		"react-router-dom": "^7.14.2",
		"recharts": "^3.8.1",
		"rehype-raw": "^7.0.0",
		"remark-gfm": "^4.0.1",
		"socket.io-client": "^4.8.3",
		"web-vitals": "^5.2.0",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@babel/preset-env": "^7.29.2",
		"@babel/runtime": "^7.29.2",
		"@chromatic-com/storybook": "^5.1.2",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@elsikora/commitizen-plugin-commitlint-ai": "^2.5.0",
		"@eslint/js": "^10.0.1",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@lhci/cli": "^0.15.1",
		"@playwright/test": "^1.59.1",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@rolldown/plugin-babel": "^0.2.3",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/exec": "^7.1.0",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.6",
		"@sentry/vite-plugin": "^5.2.0",
		"@storybook/addon-a11y": "^10.3.5",
		"@storybook/addon-docs": "^10.3.5",
		"@storybook/addon-vitest": "^10.3.5",
		"@storybook/react-vite": "^10.3.5",
		"@storybook/test": "^8.6.15",
		"@tailwindcss/postcss": "^4.2.4",
		"@tailwindcss/vite": "^4.2.4",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.8.0",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/compression": "^1.8.1",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript-eslint/eslint-plugin": "^8.59.0",
		"@typescript-eslint/parser": "^8.59.0",
		"@vitejs/devtools": "^0.1.15",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/browser": "^4.1.5",
		"@vitest/browser-playwright": "^4.1.5",
		"@vitest/coverage-v8": "^4.1.5",
		"@vitest/ui": "^4.1.5",
		"autoprefixer": "^10.5.0",
		"babel-plugin-react-compiler": "^1.0.0",
		"browserslist": "^4.28.2",
		"commitizen": "^4.3.1",
		"conventional-changelog": "^7.2.0",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.5",
		"eslint-plugin-jsdoc": "^62.9.0",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"eslint-plugin-storybook": "^10.3.5",
		"globals": "^17.5.0",
		"husky": "^9.1.7",
		"jsdom": "^29.0.2",
		"lighthouse": "^13.1.0",
		"lightningcss": "^1.32.0",
		"marked": "^18.0.2",
		"marked-gfm-heading-id": "^4.1.4",
		"playwright": "^1.59.1",
		"postcss": "^8.5.10",
		"prettier": "^3.8.3",
		"prettier-plugin-tailwindcss": "^0.7.3",
		"puppeteer": "^24.42.0",
		"puppeteer-core": "^24.39.1",
		"rollup-plugin-visualizer": "^7.0.1",
		"sass": "^1.99.0",
		"semantic-release": "^25.0.3",
		"sharp": "^0.34.5",
		"storybook": "^10.3.5",
		"stylelint": "^17.9.0",
		"stylelint-config-prettier-scss": "^1.0.0",
		"stylelint-config-standard": "^40.0.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"stylelint-order": "^8.1.1",
		"supertest": "^7.2.2",
		"typedoc": "^0.28.19",
		"typedoc-plugin-markdown": "^4.11.0",
		"typescript": "~6.0.3",
		"typescript-eslint": "^8.59.0",
		"vite": "^8.0.10",
		"vite-plugin-compression": "^0.5.1",
		"vite-plugin-pwa": "^1.2.0",
		"vite-plugin-splash-screen": "^0.2.0",
		"vitest": "^4.1.5",
		"vitest-websocket-mock": "^0.5.0",
		"wrangler": "^4.85.0"
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/@elsikora/commitizen-plugin-commitlint-ai/index.cjs"
		}
	}
}
